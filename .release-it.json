{
  "git": {
    "requireCleanWorkingDir": false,
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "changelog": "./internal/scripts/changelog.sh stdout ${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "web": false,
    "draft": false,
    "releaseNotes": "./internal/scripts/changelog.sh stdout ${version}"
  },
  "hooks": {
    "before:init": [],
    "after:bump": "./internal/scripts/changelog.sh"
  },
  "npm": {
    "publish": true,
    "publishPath": "gen/ts"
  },
  "plugins": {
    "@csmith/release-it-calver-plugin": {
      "cycle": "month",
      "separator": "."
    },
    "@release-it/bumper": {
      "out": [
        {
          "file": "VERSION",
          "type": "text/plain"
        },
        {
          "file": "gen/ts/package.json",
          "path": "version"
        }
      ]
    }
  }
}