{
    "go.lintTool": "golangci-lint-v2",
    "go.lintFlags": [
        "--path-mode=abs",
        "--fast-only"
    ],
    "go.formatTool": "custom",
    "go.alternateTools": {
        "customFormatter": "golangci-lint-v2"
    },
    "go.formatFlags": [
        "fmt",
        "--stdin"
    ],
    "go.testTimeout": "240s",
    "i18n-ally.localesPaths": [
        "i18n/locales"
    ],
    "i18n-ally.keystyle": "nested",
    "i18n-ally.displayLanguage": "en",
    "i18n-ally.sourceLanguage": "en",
    "i18n-ally.dirStructure": "file",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[vue]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
    },
    "js/ts.preferences.quoteStyle": "single",
    "js/ts.tsdk.path": "node_modules/typescript/lib",
    "js/ts.updateImportsOnFileMove.enabled": "never",
    "js/ts.preferences.importModuleSpecifier": "non-relative",
    "js/ts.preferences.importModuleSpecifierEnding": "minimal",
    "tailwindCSS.classAttributes": [
        "active-class",
        "inactive-class"
    ],
    "tailwind-fold.foldStyle": "QUOTES",
    "prettier.prettierPath": "./node_modules/prettier",
    "vitest.shellType": "terminal",
    "editor.unicodeHighlight.allowedCharacters": {
        "ℹ": true
    }
}