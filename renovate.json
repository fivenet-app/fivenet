{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>nuxt/renovate-config-nuxt",
        "helpers:pinGitHubActionDigests"
    ],
    "schedule": [
      "at any time"
    ],
    "baseBranchPatterns": ["develop"],
    "lockFileMaintenance": {
        "enabled": true
    },
    "packageRules": [
        {
            "description": "Temporarily ignore vitest 4.1.0 (Rollup/i18n JSON issue)",
            "matchManagers": ["npm"],
            "matchPackageNames": ["vitest"],
            "allowedVersions": "!/^4\\.1\\.0$/"
        },
        {
            "matchManagers": ["gomod"],
            "groupName": "go modules",
            "groupSlug": "go-modules"
        },
        {
            "matchManagers": ["gomod"],
            "matchDepTypes": ["golang"],
            "matchDepNames": ["go"],
            "groupName": "go toolchain",
            "groupSlug": "go-toolchain",
            "rangeStrategy": "bump"
        }
    ],
    "postUpdateOptions": ["gomodTidy", "pnpmDedupe"],
    "nix": {
        "enabled": true
    }
}
